# ===========================================
# Groovium (GRVM) — Environment Variables
# ===========================================
# Copy this file to `.env` and fill in the values.
# NEVER commit your real `.env` file to the repository.

# --- Lovable Cloud / Supabase (auto-provided by Lovable) ---
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# --- Chainlink CRE / Solana Oracle (backend only) ---
# Used by the `oracle-analyze` edge function and the Chainlink CRE workflow.
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_PRIVATE_KEY="base58-secret-key-of-the-service-wallet"

# --- Lovable AI Gateway (auto-provided in edge functions) ---
LOVABLE_API_KEY="auto-injected-in-edge-functions"
